---
import MainLayout from "../layouts/MainLayout.astro";
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const allBooks = await getCollection('books');
const data = allBooks[0].data;

// Derive years from the data, sorted newest-first — no more hand-maintained sections
const years = [...new Set(data.map(b => b.year))].sort((a, b) => b - a);

function renderStars(stars: number): string {
  const filled = '★'.repeat(stars);
  const empty = '☆'.repeat(5 - stars);
  return filled + empty;
}

import SubprimeAttentionCrisis from '@images/bookshelf/subprime-attention-crisis.jpg'
import NemesisGames from '@images/bookshelf/nemesis-games.jpg'
import ChildrenOfTime from '@images/bookshelf/children-of-time.jpg'
import ChildrenOfRuin from '@images/bookshelf/children-of-ruin.jpg'
import UndauntedCourage from '@images/bookshelf/undaunted-courage.jpg'
import Technopoly from '@images/bookshelf/technopoly.jpg'
import Babylon from '@images/bookshelf/babylons-ashes.jpg'
import PersepolisRising from '@images/bookshelf/persepolis-rising.jpg'
import TiamatsWrath from '@images/bookshelf/tiamats-wrath.jpg'
import MenAtArms from '@images/bookshelf/men-at-arms.jpg'
import Matter from '@images/bookshelf/matter.jpeg'
import HydrogenSonata from '@images/bookshelf/hydrogen-sonata.png'

// Map imported images so we can reference them by title when looping
const bookCovers = {
  "Subprime Attention Crisis": SubprimeAttentionCrisis,
  "Nemesis Games": NemesisGames,
  "Children of Time": ChildrenOfTime,
  "Children of Ruin": ChildrenOfRuin,
  "Undaunted Courage": UndauntedCourage,
  "Technopoly": Technopoly,
  "Babylon's Ashes": Babylon,
  "Persepolis Rising": PersepolisRising,
  "Tiamat's Wrath": TiamatsWrath,
  "Men at Arms": MenAtArms,
  "Matter": Matter,
  "Hydrogen Sonata": HydrogenSonata
}
---

<MainLayout title="Bookshelf">
  <div class="bg-white py-8 sm:py-12 lg:py-14">
    <div class="mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
      <!-- Masthead -->
      <div class="mx-auto max-w-2xl lg:mx-0">
        <p class="text-xl font-semibold leading-7 text-SignalPurp sm:text-2xl md:text-3xl">The</p>
        <h1 transition:name="leade" transition:animate="fade" class="mt-2 text-5xl font-bold leading-none tracking-tight text-SignalBlack sm:text-6xl md:text-8xl">Bookshelf</h1>
        <p class="mt-6 text-lg leading-8 text-SignalBlack">What I've been reading this year. I'm typically a giant slacker when it comes to reading—spending too much time scrolling on crap and too little time reading things of real value. Part of the logic of setting up this page is to build some social obligation to read more. We'll see if that works, fingers crossed 🤞🏼.</p>
      </div>

      <!-- One loop for all years, derived from the data -->
      {years.map(year => (
        <section class="mt-12 sm:mt-16 lg:mt-20">
          <h2 class="text-right text-xl font-semibold leading-7 text-SignalPurp sm:text-2xl md:text-3xl">{year}</h2>
          <ul class="mt-6 grid grid-cols-1 gap-x-[2.85rem] gap-y-12 border-t border-gray-200 pt-8 sm:gap-y-14 sm:pt-10 md:grid-cols-2 md:gap-x-[3.8rem] lg:grid-cols-3 lg:gap-x-[4.75rem]">
            {data.filter(book => book.year === year).map(book => (
              <li class="group">
                <a href={book.link} target="_blank" rel="noopener noreferrer" class="plain block">
                  <div class="overflow-hidden rounded-sm bg-gray-50 aspect-h-3 aspect-w-2">
                    <Image
                      src={bookCovers[book.title]}
                      alt=""
                      class="h-full w-full object-contain object-top"
                      decoding="async"
                      loading="lazy"
                      widths={[400, 600, 800]}
                      sizes="(max-width: 768px) 100vw, (max-width: 1023px) 50vw, 33vw"
                    />
                  </div>
                  <h3 class="mt-3 text-lg font-semibold leading-7 text-SignalBlack group-hover:text-gray-600 sm:text-base sm:leading-6">{book.title}</h3>
                  <p class="text-sm text-gray-500">by {book.author}</p>
                  <p class="mt-1 text-sm tracking-wide text-SignalOrange">
                    <span aria-hidden="true">{renderStars(book.stars)}</span>
                    <span class="sr-only">{book.stars} out of 5 stars</span>
                  </p>
                  <p class="mt-3 text-sm leading-6 text-gray-600">{book.description}</p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </div>
</MainLayout>
