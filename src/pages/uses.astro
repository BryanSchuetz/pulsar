const iconCloud = `<svg class="h-7 w-7" viewBox="0 0 640 640" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M112 256C112 167.6 183.6 96 272 96C319.1 96 361.4 116.4 390.7 148.7C401.3 145.6 412.5 144 424 144C490.3 144 544 197.7 544 264C544 277.2 541.9 289.9 537.9 301.8C579.5 322.9 608 366.1 608 416C608 486.7 550.7 544 480 544L176 544C96.5 544 32 479.5 32 400C32 343.2 64.9 294.1 112.7 270.6C112.3 265.8 112 260.9 112 256zM272 144C210.1 144 160 194.1 160 256C160 264.4 160.9 272.6 162.7 280.5C165.4 292.6 158.4 304.8 146.6 308.6C107.9 321 80 357.3 80 400C80 453 123 496 176 496L480 496C524.2 496 560 460.2 560 416C560 378.6 534.3 347.1 499.5 338.4C492 336.5 485.9 331.2 483 324.1C480.1 317 480.9 308.9 485 302.4C492 291.3 496 278.2 496 264.1C496 224.3 463.8 192.1 424 192.1C412.9 192.1 402.5 194.6 393.2 199C382.7 204 370.1 200.7 363.4 191.2C343.1 162.6 309.7 144.1 272.1 144.1z"/></svg>`;

const hardware = [
  {
    name: "2024 Macbook Pro 16",
    note: "Slammed with 36 GB of RAM and a 1T solid state drive.",
    url: "https://www.apple.com/macbook-pro/",
  },
  {
    name: "Gok Type-K Keyboard",
    note: "Simply put, it's the finest keyboard I've ever used. I alternate it between light linears and Topre switches. Insanely great.",
    url: "https://www.gok.design/type-k",
  },
  {
    name: "LG Ultrafine",
    note: "Single monitor gang, rise up. A crappy monitor, but a great panel at an (Apple non-ridiculous) price point.",
    url: "https://www.lg.com/us/monitors/lg-27md5kl-b-5k-uhd-led-monitor",
  },
  {
    name: "Traska Sumiteer",
    note: "Explorer vibes at an everyday price. A very readable tool watch, box sapphire, sector dial, sword hands, super luminova, and a 4Hz Miyoto 9039, etc. Highly recommend.",
    url: "https://www.traskawatch.com/collections/summiteer-collection",
  },
];

const software = [
  {
    name: "QMK",
    note: "If you're not writing your own firmware for your keyboards—you're doing it wrong.",
    url: "https://qmk.fm/",
  },
  {
    name: "Zed Editor",
    note: "The Porsche of text editors. I dock files to the right, terminal threads to the left. These days I spend most of my time with the agent, and jumping in and out of the diff views.",
    url: "https://zed.dev/",
  },
  {
    name: "Ghostty",
    note: "Visor. Mode.",
    url: "https://ghostty.org/",
  },
  {
    name: "Dia Browser",
    note: "It's not called The Rendering Engine Company of New York for a reason.",
    url: "https://www.diabrowser.com/",
  },
  {
    name: "Raycast",
    note: "I was a huge Quicksilver user back in the day, then Launchbar, AlfredApp, and now Raycast. It doesn't suck.",
    url: "https://www.raycast.com/",
  },
  {
    name: "Things",
    note: "No one does it like Cultured Code. Ruthless minimalism in the pursuit of maximal utility. I'd be lost without it.",
    url: "https://culturedcode.com/things/",
  },
  {
    name: "ZSH",
    note: "Autosuggestions, Jump, FZF, Copilot CLI, Abbreviations, Starship prompt. Gets the job done.",
    url: "https://www.zsh.org/",
  },
  {
    name: "Astro",
    note: "Been building static since before there was CSS. They do soo much right.",
    url: "https://astro.build/",
  },
  {
    name: "OpenCode / Amp",
    note: "I bounce back and forth between Amp and OpenCode, still trying to decide which one I like best. I kind of like how restrictive Amp can be (e.g. switching models mid session), but I like that flexibility in OpenCode.",
    url: "https://ampcode.com/chronicle",
  }
];

const services = [
  {
    name: "Netlify",
    note: "Static site hosting with dead-simple deploys. The free tier covers everything I need.",
    url: "https://www.netlify.com/",
  },
  {
    name: "GitHub",
    note: "Where the code lives. Enough said.",
    url: "https://github.com/",
  },
  {
    name: "Cloudflare",
    note: "DNS and CDN. Fast, reliable, and the free tier is genuinely generous.",
    url: "https://www.cloudflare.com/",
  },
];
---
<MainLayout title="Uses">
  <div class="bg-white py-8 sm:py-12 lg:py-14">
    <div class="mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl lg:mx-0">
        <p class="text-xl font-semibold leading-7 text-SignalPurp sm:text-2xl md:text-3xl">The</p>
        <h1 transition:name="leade" transition:animate="fade" class="mt-2 text-5xl font-bold leading-none tracking-tight text-SignalBlack sm:text-6xl md:text-8xl">Some Crap That I Use Most Days</h1>
        <p class="mt-6 text-lg leading-8 text-SignalBlack">That thing people do where they list out all the crap that they use to do their jobs and live their lives on a day-to-day basis—so other people can obsess about it as a way to avoid doing what they need to do in their jobs and their lives on a day-to-day basis. Also listed on <a href="https://uses.tech" class="text-SignalOrange underline decoration-1 underline-offset-2">uses.tech</a>.</p>
      </div>

      <div class="mt-12 sm:mt-16 lg:mt-20">
        <!-- Hardware -->
        <div class="mb-6 flex items-center gap-3 text-SignalBlack">
          <Fragment set:html={iconKeyboard} />
          <h2 class="text-2xl font-bold">Office / Hardware / Gear</h2>
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3">
          {hardware.map((item) => (
            <a href={item.url} target="_blank" rel="noopener noreferrer" class="group flex h-full flex-col rounded-lg border border-gray-200 p-5 transition-colors hover:border-gray-300">
              <h3 class="text-lg font-semibold text-SignalBlack group-hover:text-gray-600">{item.name}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-gray-600">{item.note}</p>
            </a>
          ))}
        </div>

        <!-- Software -->
        <div class="mb-6 mt-12 flex items-center gap-3 text-SignalBlack">
          <Fragment set:html={iconTerminal} />
          <h2 class="text-2xl font-bold">Software / Libraries / Frameworks</h2>
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3">
          {software.map((item) => (
            <a href={item.url} target="_blank" rel="noopener noreferrer" class="group flex h-full flex-col rounded-lg border border-gray-200 p-5 transition-colors hover:border-gray-300">
              <h3 class="text-lg font-semibold text-SignalBlack group-hover:text-gray-600">{item.name}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-gray-600">{item.note}</p>
            </a>
          ))}
        </div>

        <!-- Services -->
        <div class="mb-6 mt-12 flex items-center gap-3 text-SignalBlack">
          <Fragment set:html={iconCloud} />
          <h2 class="text-2xl font-bold">Services / Subscriptions</h2>
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3">
          {services.map((item) => (
            <a href={item.url} target="_blank" rel="noopener noreferrer" class="group flex h-full flex-col rounded-lg border border-gray-200 p-5 transition-colors hover:border-gray-300">
              <h3 class="text-lg font-semibold text-SignalBlack group-hover:text-gray-600">{item.name}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-gray-600">{item.note}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</MainLayout>
