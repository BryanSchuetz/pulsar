---
import MusicPreview from '../components/MusicPreview.astro';
import BlogPreview from '../components/BlogPreview.astro';
import MainLayout from '../layouts/MainLayout.astro'
---
<MainLayout>
  <div class="bg-white py-8 sm:py-12 lg:py-14">
    <div class="mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl lg:mx-0">
        <p class="text-xl font-semibold leading-7 text-SignalPurp sm:text-2xl md:text-3xl">The</p>
      <h1 transition:name="leade" transition:animate="fade" class="mt-2 text-5xl font-bold leading-none tracking-tight text-SignalBlack sm:text-6xl md:text-8xl">Distress Signal</h1>
        <p class="mt-5 text-base leading-7 text-SignalBlack sm:mt-6 sm:text-lg sm:leading-8">A personal hypertext of <a class="featured" href="https://indieweb.social/@zero_gravitas" rel="me">Bryan Schuetz</a> | <a class="featured" href="/feed.xml">RSS</a></p>
      </div>
    </div>
  </div>
  <BlogPreview />
  <MusicPreview />
</MainLayout>
