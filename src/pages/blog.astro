---
import BlogRoll from '../components/BlogRoll.astro'
import MainLayout from '../layouts/MainLayout.astro'
---
<MainLayout>
  <div class="bg-white py-8 sm:py-12 lg:py-14 ">
    <div class="mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl lg:mx-0">
        <p class="text-xl font-semibold leading-7 text-SignalPurp sm:text-2xl md:text-3xl">The</p>
      <h1 transition:name="leade" transition:animate="fade" class="mt-2 text-5xl font-bold leading-none tracking-tight text-SignalBlack sm:text-6xl md:text-8xl"> Blog</h1>
        <p class="mt-6 text-lg leading-8 text-SignalBlack">Jibber jabber from the <a href="/">The Distress Signal</a></p>
      </div>
    </div>
  </div>
  <BlogRoll />
</MainLayout>
